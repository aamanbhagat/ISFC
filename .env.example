# ── Canonical origin ─────────────────────────────────────────
# Local dev sets this to http://localhost:3000 in .env.local.
# In production set it to the live origin (no trailing slash).
NEXT_PUBLIC_SITE_URL=https://ifsckosh.tech

# ── Supabase (Postgres) ──────────────────────────────────────
# Postgres connection string. Use the Transaction pooler (port 6543):
#   Supabase dashboard → Project Settings → Database → Connection string.
# When unset, the app falls back to the bundled sample dataset
# (data/sample-branches.json) so the site runs with zero config.
SUPABASE_DB_URL=

# ── Data sync (scripts/sync-supabase.ts) ─────────────────────
# Bulk source: razorpay/ifsc release artifact. Override if the asset
# name/URL changes. The script also accepts a local file path.
IFSC_DATASET_URL=

# ── Analytics (Google Analytics 4) ───────────────────────────
# Only loads in production builds. Defaults to the project's GA id.
NEXT_PUBLIC_GA_ID=G-HYKJDCL1LL

# ── Search Console / Bing verification (optional) ────────────
# For GSC "HTML tag" method, paste the token (the content="" value).
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_BING_SITE_VERIFICATION=

# ── Contact + social (optional, used in JSON-LD) ─────────────
NEXT_PUBLIC_CONTACT_EMAIL=contact@ifsckosh.tech
NEXT_PUBLIC_SOCIAL_LINKS=
