# ── Canonical origin ─────────────────────────────────────────
# Local dev sets this to http://localhost:3000 in .env.local.
# In production set it to the live origin (no trailing slash).
NEXT_PUBLIC_SITE_URL=https://ifsckosh.in

# ── Turso (libSQL) ───────────────────────────────────────────
# Create a free DB:  turso db create ifsckosh
#   turso db show ifsckosh --url      → TURSO_DATABASE_URL
#   turso db tokens create ifsckosh   → TURSO_AUTH_TOKEN
# When unset, the app falls back to the bundled sample dataset
# (data/sample-branches.json) so the site runs with zero config.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# ── Data sync (scripts/sync-ifsc.ts) ─────────────────────────
# Bulk source: razorpay/ifsc release artifact. Override if the asset
# name/URL changes. The script also accepts a local file path.
IFSC_DATASET_URL=

# ── Search Console / Bing verification (optional) ────────────
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_BING_SITE_VERIFICATION=

# ── Contact + social (optional, used in JSON-LD) ─────────────
NEXT_PUBLIC_CONTACT_EMAIL=contact@ifsckosh.in
NEXT_PUBLIC_SOCIAL_LINKS=
